# =====================================================================
# ALLOW-LIST policy: ignore everything by default, then permit only
# source / config / documentation file types. This guarantees that
# run outputs (structures, figures, logs, weights, etc.) are NEVER
# pushed, even brand-new output formats we haven't seen before.
# To track a new file type, add a "!*.ext" line below.
# =====================================================================

# 1) Ignore everything...
*

# 2) ...but still descend into directories so allowed files are reachable
!*/

# 3) Allow source / config / docs
!.gitignore
!*.py
!*.R
!*.sh
!*.bash
!*.md
!*.rst
!*.txt.example
!*.json
!*.jsonc
!*.xml
!*.yml
!*.yaml
!*.toml
!*.cfg
!*.ini
!*.conf
!*.csv.example

# 4) Re-exclude things that are source-typed but are NOT real source:
#    - presentation/slide material
#    - the large model-weights folder (params/)
#    - python caches
presentation/
params/
__pycache__/
*.pyc
*.pyo

# 5) Editor / tooling config (local, not part of the project)
.vscode/
.claude/
.codex
.idea/
